#!/usr/bin/env bash
# ============================================================================
# DMP Project Setup Script
# ============================================================================
# Idempotent entrypoint that replaces the multi-step README guide.
# Safe to re-run indefinitely — every step guards against duplicate work.
# ============================================================================
set -euo pipefail

# ─── Configuration ──────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

ENV_FILE=".env"
ENV_EXAMPLE=".env.example"
DATA_DIR="data/raw/data"
SAMPLE_DATA_DIR="sample-data"
GIT_HOOKS_PATH=".githooks"
HEALTH_URL="http://localhost:8000/health"
STATUS_URL="http://localhost:8000/api/v1/system/status"

# ─── Color helpers ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${GREEN}[INFO]${NC}  $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; }
banner(){ echo -e "${CYAN}$*${NC}"; }

# ─── Helper: check prerequisite commands ────────────────────────────────────
check_prereqs() {
    local missing=0
    for cmd in docker git curl; do
        if ! command -v "$cmd" &>/dev/null; then
            error "'$cmd' is required but not installed."
            missing=1
        fi
    done
    if [ "$missing" -ne 0 ]; then
        exit 1
    fi

    # Verify Docker is actually running
    if ! docker info &>/dev/null; then
        error "Docker daemon is not running. Please start Docker and try again."
        exit 1
    fi

    # Verify docker compose (v2) is available
    if ! docker compose version &>/dev/null; then
        error "Docker Compose v2 is required. Check your Docker installation."
        exit 1
    fi

    info "All prerequisites satisfied."
}

# ─── Step 1: Environment File ───────────────────────────────────────────────
setup_env() {
    local needs_profile_prompt=false

    if [ -f "$ENV_FILE" ]; then
        # .env exists — check if COMPOSE_PROFILES is set
        if grep -q "^COMPOSE_PROFILES=" "$ENV_FILE" 2>/dev/null; then
            info "✓ .env exists with COMPOSE_PROFILES, skipping creation."
        else
            warn ".env exists but is missing COMPOSE_PROFILES. Prompting..."
            needs_profile_prompt=true
        fi
    else
        info "Creating .env from .env.example..."
        cp "$ENV_EXAMPLE" "$ENV_FILE"
        needs_profile_prompt=true
    fi

    if [ "$needs_profile_prompt" = true ]; then
        echo ""
        banner "Which Docker Compose profile would you like?"
        echo "  [1] backend only    (API, workers, MLflow — recommended for backend dev)"
        echo "  [2] backend + frontend"
        echo "  [3] full            (all 10 services — demos, production-like testing)"
        echo "  [4] monitoring only (Prometheus, Grafana, DbGate)"
        echo "  [5] analytics only  (Jupyter)"
        read -rp "Enter choice [1-5] (default: 1): " profile_choice
        case "${profile_choice}" in
            2) prof="backend,frontend" ;;
            3) prof="full" ;;
            4) prof="monitoring" ;;
            5) prof="analytics" ;;
            *) prof="backend" ;;
        esac

        if grep -q "^COMPOSE_PROFILES=" "$ENV_FILE" 2>/dev/null; then
            sed -i "s/^COMPOSE_PROFILES=.*/COMPOSE_PROFILES=${prof}/" "$ENV_FILE"
        else
            echo "# Docker Compose profiles (comma-separated)." >> "$ENV_FILE"
            echo "# Options: backend, frontend, analytics, monitoring, full" >> "$ENV_FILE"
            echo "# \"full\" starts ALL services." >> "$ENV_FILE"
            echo "COMPOSE_PROFILES=${prof}" >> "$ENV_FILE"
        fi
        info "✓ COMPOSE_PROFILES=${prof} written to ${ENV_FILE}"
    fi

    # Source .env so COMPOSE_PROFILES is available to docker compose
    set -a; source "$ENV_FILE"; set +a
}

# ─── Step 2: Data (DVC or sample fallback) ──────────────────────────────────
setup_data() {
    if [ -d "$DATA_DIR" ] && [ "$(ls -A "$DATA_DIR" 2>/dev/null)" ]; then
        info "✓ Data directory '${DATA_DIR}' is not empty, skipping data pull."
        return
    fi

    if command -v dvc &>/dev/null && dvc remote list 2>/dev/null | grep -q gdrive; then
        info "DVC remote 'gdrive' configured. Pulling data (~4 GB)..."
        dvc pull || {
            warn "dvc pull failed. Trying sample data fallback..."
            fallback_sample_data
        }
    elif [ -d "$SAMPLE_DATA_DIR" ] && [ "$(ls -A "$SAMPLE_DATA_DIR" 2>/dev/null)" ]; then
        warn "DVC not configured. Using sample data fallback."
        fallback_sample_data
    else
        warn "No data available (DVC not configured, no sample data directory)."
        warn "Backend will start but data-dependent endpoints will fail."
        warn "To obtain data later, run: dvc pull"
    fi
}

fallback_sample_data() {
    mkdir -p "$DATA_DIR"
    cp -r "$SAMPLE_DATA_DIR"/* "$DATA_DIR/" 2>/dev/null || true
    info "Sample data copied to ${DATA_DIR}."
    warn "Model training will not work with sample data."
    warn "To obtain the full dataset: install DVC and run 'dvc pull'"
}

# ─── Step 3: Git Hooks ──────────────────────────────────────────────────────
setup_hooks() {
    if [ ! -d "$GIT_HOOKS_PATH" ]; then
        info "No .githooks directory found, skipping hooks setup."
        return
    fi

    local current_hooks_path
    current_hooks_path=$(git config core.hooksPath 2>/dev/null || echo "")

    if [ "$current_hooks_path" = "$GIT_HOOKS_PATH" ]; then
        info "✓ Git hooks already configured (core.hooksPath = ${GIT_HOOKS_PATH})."
    else
        info "Configuring Git hooks path → ${GIT_HOOKS_PATH}..."
        git config core.hooksPath "$GIT_HOOKS_PATH"
        if [ -f "${GIT_HOOKS_PATH}/pre-push" ]; then
            chmod +x "${GIT_HOOKS_PATH}/pre-push"
        fi
        info "✓ Git hooks path set to ${GIT_HOOKS_PATH}."
    fi
}

# ─── Step 4: Build and Start ────────────────────────────────────────────────
build_and_start() {
    info "Building Docker images (using layer cache)..."
    docker compose build

    info "Starting services (profiles: ${COMPOSE_PROFILES:-backend})..."
    docker compose up -d --wait

    info "Waiting for backend to become healthy..."
    local attempt=0
    local max_attempts=60
    while [ "$attempt" -lt "$max_attempts" ]; do
        attempt=$((attempt + 1))
        if curl -sf "$HEALTH_URL" > /dev/null 2>&1; then
            info "✓ Backend is healthy (attempt ${attempt})."
            return 0
        fi
        if [ "$attempt" -eq "$max_attempts" ]; then
            error "Backend did not become healthy after ${max_attempts} attempts (~${max_attempts}s)."
            error "Check logs: docker compose logs backend"
            docker compose ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}"
            return 1
        fi
        sleep 1
    done
}

# ─── Step 5: Verify System Status ───────────────────────────────────────────
verify_status() {
    info "Checking system status (${STATUS_URL})..."

    local status_json
    status_json=$(curl -sf "$STATUS_URL" 2>/dev/null || echo "")

    if [ -z "$status_json" ]; then
        warn "System status endpoint not available yet (Phase 4 not implemented)."
        warn "Skipping migration and data availability checks."
        return
    fi

    # Check pending migrations
    local pending
    pending=$(echo "$status_json" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('database', {}).get('pending_migrations', -1))
except Exception:
    print(-1)
" 2>/dev/null || echo "-1")

    if [ "$pending" = "-1" ]; then
        warn "Could not determine migration status."
    elif [ "$pending" != "0" ]; then
        warn "Database may have pending migrations (pending_migrations=${pending})."
        warn "Check: docker compose logs backend | grep alembic"
    else
        info "✓ Database schema is up to date."
    fi

    # Check data availability
    local data_avail
    data_avail=$(echo "$status_json" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('dvc', {}).get('data_available', False))
except Exception:
    print(False)
" 2>/dev/null || echo "False")

    if [ "$data_avail" != "True" ]; then
        warn "Data is not fully available. Some endpoints may return errors."
    else
        info "✓ Data is available."
    fi
}

# ─── Step 6: Seed Reference Data ────────────────────────────────────────────
seed_if_needed() {
    local pg_user="${POSTGRES_USER:-dmp_user}"
    local pg_db="${POSTGRES_DB:-dmp_db}"

    # Check if the location table already has rows
    local has_locations
    has_locations=$(docker compose exec -T db psql \
        -U "$pg_user" \
        -d "$pg_db" \
        -t -c "SELECT COUNT(*) FROM location;" 2>/dev/null | tr -d '[:space:]' || echo "0")

    if [ "$has_locations" != "0" ] && [ "$has_locations" != "" ]; then
        info "✓ Database already seeded (${has_locations} locations found)."
        return
    fi

    info "Seeding reference data (locations, devices, metadata)..."
    if docker compose exec -T backend python -m src.seeder --phase reference 2>/dev/null; then
        info "✓ Reference data seeded successfully."
    else
        warn "Seeding reference data failed. You can retry later with:"
        warn "  docker compose exec backend python -m src.seeder --phase reference"
    fi
}

# ─── Print Summary ──────────────────────────────────────────────────────────
print_summary() {
    echo ""
    banner "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    banner "  DMP Smart City AI Platform is ready!"
    banner "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  Services:"
    echo "    API Docs:   http://localhost:8000/docs"
    echo "    MLflow UI:  http://localhost:5000"
    echo ""

    if docker compose ps --format "{{.Names}}" 2>/dev/null | grep -q "dmp_frontend"; then
        echo "    Frontend:    http://localhost:3001"
    fi
    if docker compose ps --format "{{.Names}}" 2>/dev/null | grep -q "dmp_jupyter"; then
        echo "    Jupyter:     http://localhost:8888"
    fi
    if docker compose ps --format "{{.Names}}" 2>/dev/null | grep -q "dmp_grafana"; then
        echo "    Grafana:     http://localhost:3003"
        echo "    Prometheus:  http://localhost:9090"
    fi
    if docker compose ps --format "{{.Names}}" 2>/dev/null | grep -q "dbgate-web"; then
        echo "    DbGate:      http://localhost:3002"
    fi
    echo ""
    echo "  To change profiles, edit COMPOSE_PROFILES in .env"
    echo "  To add full data, configure DVC and run: dvc pull"
    echo "  Run './setup' again anytime — it is safe and idempotent."
    echo ""
}

# ─── Main ───────────────────────────────────────────────────────────────────
main() {
    echo ""
    banner "╔══════════════════════════════════════════╗"
    banner "║     DMP Project Setup (Idempotent)       ║"
    banner "╚══════════════════════════════════════════╝"
    echo ""

    check_prereqs
    setup_env
    setup_data
    setup_hooks
    build_and_start
    verify_status
    seed_if_needed
    print_summary
}

main "$@"
